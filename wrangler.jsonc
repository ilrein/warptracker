{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "warptracker",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "warptracker.com/*", "zone_name": "warptracker.com" },
    { "pattern": "www.warptracker.com/*", "zone_name": "warptracker.com" }
  ]
}
